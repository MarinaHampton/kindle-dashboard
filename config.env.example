# Copy to config.env (gitignored) and fill in your values.
# config.env holds your private Google Calendar token — never commit it.

export KD_LAT=40.71                 # your latitude
export KD_LON=-74.0                 # your longitude
export KD_CITY="Your City"          # label shown on the panel
export KD_PROXMOX=root@192.168.1.10 # host the renderer SSHes for stats (optional)

# Google Calendar -> Settings -> Integrate calendar -> "Secret address in iCal format"
export KD_ICS="https://calendar.google.com/calendar/ical/.../private-XXXX/basic.ics"
